{
  "name": "store-web-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "nest-backend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "lint": "npm run lint -w frontend",
    "test": "npm run test -w frontend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "dev:nest": "npm run start:dev -w nest-backend",
    "build:nest": "npm run build -w nest-backend"
  }
}
